# Copy to .env.development.local to override defaults during `npm run dev`.
#
# Default behaviour: `vite.config.ts` proxies /search, /id, /img to
# http://127.0.0.1:8202 (the port docker-compose.yml maps for the Go backend).
# Setting VITE_API_BASE_URL bypasses the proxy and points the app at an
# absolute backend URL instead (relies on the backend's permissive CORS).
#
# VITE_API_BASE_URL=https://soap.nivoynov.dev
